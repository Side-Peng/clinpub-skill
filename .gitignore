# clinpub .gitignore

# Raw data — never commit patient data
01_RawData/
*.csv
*.xlsx
*.xls
*.sav
*.dta
*.sas7bdat

# Preprocessed data
02_PreprocessedData/data/

# Generated outputs (large files)
04_Outputs/**/*.png
04_Outputs/**/*.tiff
04_Outputs/**/*.pdf
03_AnalysisMethods/**/main.R
!03_AnalysisMethods/**/README.md

# API keys and secrets
.env
.env.*
*.key
secrets.json

# R session artifacts
.Rhistory
.RData
.Rproj.user/
*.Rproj
.Rprofile

# Python artifacts
__pycache__/
*.pyc
*.pyo
.idea/
*.egg-info/

# Node artifacts
node_modules/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Planning working files (keep structure, ignore drafts)
.planning/phases/**/*-draft.md

# Release artifacts (generated by CI)
*.tar.gz
checksums.txt
